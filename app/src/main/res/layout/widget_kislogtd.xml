<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="Успеватель"
        android:src="@drawable/ic_widget_logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Успеватель"
        android:textColor="#0D7C5C"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Нажмите, чтобы открыть"
        android:textColor="#666666"
        android:textSize="12sp" />

    <ImageView
        android:id="@+id/widget_fab"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:contentDescription="Быстрый захват"
        android:padding="12dp"
        android:background="@drawable/widget_fab_bg"
        android:src="@android:drawable/ic_input_add" />

</LinearLayout>
